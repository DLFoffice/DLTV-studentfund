rules_version = '2';

// ============================================================
// Security Rules — DLTV Fund (v6 : fail-closed + ภาคเรียน)
// ------------------------------------------------------------
// เปลี่ยนจาก v3/v5 อย่างมีนัยสำคัญ:
//  1. "ครู/เจ้าหน้าที่" ต้องถูกประกาศชัดเจน (admins/... หรือ accounts.role=='staff')
//     เดิมใช้ !isStudentAcct() แปลว่า "ใครที่ยังไม่มีเอกสาร accounts = ครู"
//     → ใครก็ตามที่สมัคร Firebase Auth ได้ จะอ่าน/เขียนข้อมูลเด็กครบ 72 คนทันที
//  2. บัญชีนักเรียนแก้ role / no / username / email / name ของตัวเองไม่ได้อีก
//     (เดิมแก้ role เป็นค่าอื่นแล้วเลื่อนขั้นตัวเองเป็นครูได้)
//  3. บัญชีนักเรียนผูก studentId เองได้ แต่ต้องเป็นเอกสารที่ "ลำดับ" ตรงกับบัญชีเท่านั้น
//  4. เพิ่ม roster (ทะเบียนสาธารณะ เก็บแค่ ลำดับ+ชื่อ) สำหรับหน้าสมัครสมาชิก
//     → register.html ไม่ต้องอ่าน collection students อีกต่อไป
//  5. เพิ่ม settings (ภาคเรียนที่เปิดให้กรอก)
//
// ติดตั้ง: Firebase Console → Firestore Database → Rules → วางทั้งหมด → Publish
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    /* ---------- helpers ---------- */
    function signedIn()  { return request.auth != null; }
    function myUid()     { return request.auth.uid; }
    function acctPath()  { return /databases/$(database)/documents/accounts/$(myUid()); }
    function hasAcct()   { return signedIn() && exists(acctPath()); }
    function acct()      { return get(acctPath()).data; }

    function isAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }
    // ครู/เจ้าหน้าที่ = แอดมิน หรือบัญชีที่ "แอดมินตั้ง role = staff ให้" เท่านั้น
    function isStaff()   { return isAdmin() || (hasAcct() && acct().role == 'staff'); }
    function isStudent() { return hasAcct() && acct().role == 'student'; }

    // ฟิลด์ที่เจ้าของบัญชีห้ามแก้เอง (แอดมินแก้ได้)
    function keepsLockedFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
               .hasAny(['role', 'no', 'username', 'email', 'name']) == false;
    }
    // ผูก studentId ได้เฉพาะเอกสารที่ "ลำดับ" ตรงกับบัญชีตัวเอง
    function studentDocMatchesMyNo(sid) {
      return exists(/databases/$(database)/documents/students/$(sid))
        && get(/databases/$(database)/documents/students/$(sid)).data.no == resource.data.no;
    }

    /* ---------- students : ข้อมูลอ่อนไหว (เลขบัตร ปชช. / บัญชีธนาคาร) ---------- */
    match /students/{studentId} {
      // ครู/แอดมิน อ่านได้ทั้งหมด
      // นักเรียน อ่านได้เฉพาะเอกสารตัวเอง + เอกสารที่ "ลำดับ" ตรงกับบัญชี (ใช้ตอนผูกบัญชี)
      allow read: if isStaff()
        || (isStudent() && (acct().studentId == studentId || resource.data.no == acct().no));

      allow create, delete: if isStaff();

      // นักเรียนแก้ได้เฉพาะเอกสารตัวเอง และห้ามแก้ ลำดับ / เลขบัตร / ชื่อ
      allow update: if isStaff()
        || (isStudent()
            && acct().studentId == studentId
            && request.resource.data.no   == resource.data.no
            && request.resource.data.id   == resource.data.id
            && request.resource.data.name == resource.data.name);
    }

    /* ---------- roster : ทะเบียนสาธารณะสำหรับหน้าสมัคร (ลำดับ + ชื่อ เท่านั้น) ---------- */
    // ห้ามใส่เลขบัตร ปชช. / บัญชีธนาคาร / ที่อยู่ ลงใน collection นี้เด็ดขาด
    match /roster/{noKey} {
      allow get: if true;
      allow list: if isStaff();
      allow write: if isStaff();
    }

    /* ---------- settings : ภาคเรียนที่เปิดให้กรอก ---------- */
    match /settings/{key} {
      allow read: if signedIn();
      allow write: if isStaff();
    }

    /* ---------- usernames : ตารางแปลง username -> email ---------- */
    match /usernames/{username} {
      allow get: if true;
      allow list: if isStaff();
      allow create: if isStaff()
        || (signedIn() && request.resource.data.email == request.auth.token.email);
      allow update, delete: if isStaff();
    }

    /* ---------- registered : กันสมัครซ้ำ 1 ลำดับ = 1 บัญชี ---------- */
    match /registered/{noKey} {
      allow get: if true;
      allow list: if isStaff();
      allow create: if signedIn()
        && request.resource.data.uid == myUid()
        && noKey == 'no-' + string(acct().no);
      allow update, delete: if isStaff();
    }

    /* ---------- accounts : ระเบียนบัญชีผู้ใช้ ---------- */
    match /accounts/{uid} {
      allow read: if isAdmin() || (signedIn() && myUid() == uid);

      // สมัครเอง: role ต้องเป็น student, ห้ามพก studentId มาเอง,
      // ลำดับต้องมีอยู่ใน roster และยังไม่มีใครจองลำดับนั้น
      allow create: if isStaff()
        || (signedIn() && myUid() == uid
            && request.resource.data.role == 'student'
            && !('studentId' in request.resource.data)
            && exists(/databases/$(database)/documents/roster/$('no-' + string(request.resource.data.no)))
            && !exists(/databases/$(database)/documents/registered/$('no-' + string(request.resource.data.no))));

      // เจ้าของบัญชีแก้ได้: สถานะรหัสผ่าน และ "ผูก studentId" ที่ลำดับตรงกันเท่านั้น
      allow update: if isStaff()
        || (signedIn() && myUid() == uid
            && keepsLockedFields()
            && (request.resource.data.get('studentId', '') == resource.data.get('studentId', '')
                || studentDocMatchesMyNo(request.resource.data.studentId)));

      allow delete: if isAdmin();
    }

    /* ---------- loginLogs : เขียนอย่างเดียว อ่านเฉพาะครู/แอดมิน ---------- */
    match /loginLogs/{logId} {
      allow create: if signedIn();
      allow read: if isStaff();
      allow update, delete: if false;
    }

    /* ---------- staffRequests : คำขอรับรหัสจากครู/เจ้าหน้าที่ ----------
       ครูที่ยังไม่มีบัญชี (ยังไม่ล็อกอิน) ส่งคำขอได้ → status ต้องเป็น 'pending'
       เท่านั้น และจำกัดฟิลด์/ความยาวเพื่อกันสแปม
       อ่าน/อนุมัติ/ลบ ได้เฉพาะครู/แอดมิน (หน้า accounts.html) */
    match /staffRequests/{reqId} {
      allow create: if request.resource.data.status == 'pending'
        && request.resource.data.keys().hasOnly(['name','position','school','email','note','status','createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2 && request.resource.data.name.size() <= 120
        && request.resource.data.position is string && request.resource.data.position.size() <= 100
        && request.resource.data.school is string && request.resource.data.school.size() <= 200
        && request.resource.data.email is string
        && request.resource.data.email.matches('[^@\\s]+@[^@\\s]+[.][^@\\s]+')
        && request.resource.data.email.size() <= 200;
      allow read, list: if isStaff();
      allow update, delete: if isStaff();
    }

    /* ---------- admins : เพิ่มผ่าน Firebase Console เท่านั้น ---------- */
    match /admins/{email} {
      allow get: if signedIn() && request.auth.token.email == email;
      allow list, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
