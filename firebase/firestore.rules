rules_version = '2';

// ============================================================
// Security Rules — สำคัญมาก เพราะข้อมูลนี้เป็นข้อมูลอ่อนไหวของผู้เยาว์
// (เลขบัตร ปชช., บัญชีธนาคาร, ที่อยู่, เบอร์โทร)
//
// วิธีติดตั้ง: Firebase Console → Firestore Database → Rules
// → วางเนื้อหาไฟล์นี้ทั้งหมด → Publish
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ข้อมูลนักเรียน: อ่าน/เขียนได้เฉพาะผู้ใช้ที่ล็อกอินเท่านั้น
    match /students/{studentId} {
      allow read, write: if request.auth != null;
    }

    // ปฏิเสธทุกอย่างที่เหลือ
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// ------------------------------------------------------------
// ขั้นสูง (ทำภายหลังได้): ถ้าต้องการจำกัดเฉพาะรายชื่ออีเมลที่อนุญาต
// ให้เปลี่ยนเงื่อนไข students เป็นแบบนี้ แล้วสร้าง collection "allowlist"
// ที่มี document id เป็นอีเมลของเจ้าหน้าที่แต่ละคน:
//
//   match /students/{studentId} {
//     allow read, write: if request.auth != null
//       && exists(/databases/$(database)/documents/allowlist/$(request.auth.token.email));
//   }
//   match /allowlist/{email} {
//     allow read: if request.auth != null;
//     allow write: if false;   // เพิ่มรายชื่อผ่าน Console เท่านั้น
//   }
// ------------------------------------------------------------
